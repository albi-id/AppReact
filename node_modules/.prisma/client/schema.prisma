datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Enums para roles y tipos de vehículo
enum Role {
  USER
  DRIVER
  ADMIN
}

enum VehicleType {
  TAXI
  TRAFIC
  MOTO
}

// Modelo principal de usuario (solicitante, conductor o admin)
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String // Hasheada (usaremos bcrypt en código)
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  driverProfile       DriverProfile? // Relación 1:1 con perfil conductor (opcional)
  servicesAsRequester Service[]      @relation("Requester")
  servicesAsDriver    Service[]      @relation("Driver")
}

// Perfil específico para conductores
model DriverProfile {
  id           String      @id @default(uuid())
  userId       String      @unique
  vehicleType  VehicleType
  isOnline     Boolean     @default(false)
  lastLocation Json? // { lat: Float, lng: Float } temporalmente
  updatedAt    DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Modelo de servicio/viaje (el core del negocio)
model Service {
  id            String         @id @default(uuid())
  requesterId   String
  driverId      String?
  type          VehicleType
  pickupLat     Float?
  pickupLng     Float?
  status        ServiceStatus  @default(REQUESTED)
  requestedAt   DateTime       @default(now())
  acceptedAt    DateTime?
  arrivedAt     DateTime?
  waitStartAt   DateTime?
  waitEndAt     DateTime?
  amount        Float? // Calculado al final (ARS)
  paymentMethod PaymentMethod?
  paidAt        DateTime? // ← Nuevo: fecha de pago
  notes         String?

  requester User  @relation("Requester", fields: [requesterId], references: [id])
  driver    User? @relation("Driver", fields: [driverId], references: [id])

  @@index([status])
  @@index([requesterId])
  @@index([driverId])
}

model Tariff {
  id          String      @id @default(uuid())
  vehicleType VehicleType @unique
  hourlyRate  Float
  currency    String      @default("ARS")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

enum ServiceStatus {
  REQUESTED
  OFFERED
  ACCEPTED
  ARRIVED
  WAITING
  COMPLETED
  CANCELED
  REJECTED
  PAID
}

enum PaymentMethod {
  CASH
  WALLET
}
