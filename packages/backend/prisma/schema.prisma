datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Enums para roles y tipos de vehículo
enum Role {
  USER
  DRIVER
  ADMIN
}

enum VehicleType {
  TAXI
  TRAFIC
  MOTO
}

// Modelo principal de usuario (solicitante, conductor o admin)
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  role          Role     @default(USER)
  firstName     String?
  lastName      String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  driverProfile DriverProfile?
  services      Service[] @relation("ServiceRequester")
  assignedServices Service[] @relation("ServiceDriver")
  professional  Professional?

  @@map("users")
}



// Perfil específico para conductores
model DriverProfile {
  id          String      @id @default(uuid())
  userId      String      @unique
  vehicleType VehicleType
  isOnline    Boolean     @default(false)
  lastLocation Json?       // { lat: Float, lng: Float } temporalmente
  updatedAt   DateTime    @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Service {
  id            String   @id @default(cuid())
  requesterId   String
  driverId      String?
  
  type          VehicleType
  pickupLat     Float?
  pickupLng     Float?
  
  status        ServiceStatus @default(REQUESTED)
  amount        Float?
  rating        Int?          // 1 a 5
  review        String?

  requestedAt   DateTime @default(now())
  acceptedAt    DateTime?
  arrivedAt     DateTime?
  waitEndAt     DateTime?
  paidAt        DateTime?

  requester     User     @relation("ServiceRequester", fields: [requesterId], references: [id])
  driver        User?    @relation("ServiceDriver", fields: [driverId], references: [id])

  @@map("services")
}

model Tariff {
  id          String      @id @default(uuid())
  vehicleType VehicleType @unique
  hourlyRate  Float
  currency    String      @default("ARS")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

enum ServiceStatus {
  REQUESTED
  OFFERED
  ACCEPTED
  ARRIVED
  WAITING
  COMPLETED
  CANCELED
  REJECTED
  PAID  
}

enum PaymentMethod {
  CASH
  WALLET
}

// =============================================
// PROFESIONALES DESTACADOS (Suscripción Premium)
// =============================================

model Professional {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id])

  fullName              String
  profession            String
  description           String?
  rating                Float    @default(0.0)
  reviewCount           Int      @default(0)
  isActive              Boolean  @default(false)     // Debe ser aprobado por admin
  subscriptionEnd       DateTime?

  // Campos nuevos para el formulario
  phone                 String?
  address               String?
  dniFrontUrl           String?   // Foto DNI Frente
  dniBackUrl            String?   // Foto DNI Dorso
  certificateUrl        String?   // Certificado de buena conducta

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("professionals")
}
