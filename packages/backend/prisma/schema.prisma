datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}
generator client {
  provider = "prisma-client-js"
}
// ==================== ENUMS ====================
enum Role {
  USER
  PROFESSIONAL
  ADMIN
}
enum ServiceStatus {
  REQUESTED
  OFFERED
  ACCEPTED
  ARRIVED
  COMPLETED
  CANCELLED
  REJECTED
  PAID
  WAITING
  CHAT
}
enum ProfessionalStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}
enum Modality {
  TIME_BASED
  FIXED_PRICE
  HIGHLIGHTED
}
// ==================== MODELOS =====================
model User {
  id String @id @default(cuid())
  email String @unique
  password String
  role Role @default(USER)
  firstName String?
  lastName String?
  photoUrl String?
  address String?
  lastLocation  Unsupported("gis.geography(Point, 4326)")?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  provinceId String?
  cityId String?
 
  province Province? @relation(fields: [provinceId], references: [id])
  city City? @relation(fields: [cityId], references: [id])
  services Service[] @relation("ServiceRequester")
  professional Professional?
  sentMessages Message[] @relation("SentMessages")  
  receivedMessages Message[] @relation("ReceivedMessages")  
  @@map("users")
}
model Professional {
  id String @id @default(cuid())
  userId String @unique
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName String
  profession String
  description String?
  phone String?
  address String?
  dniFrontUrl String?
  dniBackUrl String?
  certificateUrl String?
  rating Float @default(0.0)
  reviewCount Int @default(0)
  isActive Boolean @default(false)
  status ProfessionalStatus @default(PENDING)
  modalities Modality[]
  vehicleType String?
  lastLocation  Unsupported("gis.geography(Point, 4326)")?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  rejectCount     Int      @default(0)
  lastRejectAt    DateTime?
  provinceId String?  
  cityId String?  
  province Province? @relation(fields: [provinceId], references: [id])  
  city City? @relation(fields: [cityId], references: [id])  
  // Relación con servicios donde este profesional es quien presta el servicio
  services Service[] @relation("ServiceProfessional")
  @@map("professionals")
  @@index([provinceId, cityId])
  @@index([isActive, status])
  @@index([profession])
  @@index([lastLocation], type: Gist)   // ← Índice geoespacial clave
}
model Service {
  id String @id @default(cuid())
  requesterId String
  professionalId String?
  type String
  pickupLat Float?
  pickupLng Float?
  pickupLocation Unsupported("gis.geography(Point, 4326)")?
  pickupAddress   String?
  pickupAddressExtra String?    // Ej: "Departamento 3B, 2do piso, timbre negro"
  reference         String?     // "Al lado del supermercado", "Casa con rejas blancas"
  floor             String?     // Piso / Departamento
  doorNumber        String?     // Número de puerta
  provinceId String?  
  cityId String?  
  status ServiceStatus @default(REQUESTED)
  amount Float?
  rating Int?
  review String?
  requestedAt DateTime @default(now())
  acceptedAt DateTime?
  arrivedAt DateTime?
  completedAt DateTime?
  paidAt DateTime?
  requester User @relation("ServiceRequester", fields: [requesterId], references: [id])
  professional Professional? @relation("ServiceProfessional", fields: [professionalId], references: [id])
  messages Message[]  
  @@map("services")
  @@index([requesterId, status])
  @@index([professionalId, status])
  @@index([pickupLocation], type: Gist)   
  @@index([provinceId, cityId])
}
model Message {
  id String @id @default(cuid())
  serviceId String
  senderId String
  receiverId String
  content String
  read Boolean @default(false)
  createdAt DateTime @default(now())
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  sender User @relation("SentMessages", fields: [senderId], references: [id])
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id])
  @@index([serviceId])
  @@index([senderId])
  @@index([receiverId])
}
model Province {
  id String @id @default(cuid())
  name String @unique
  cities City[]
  users User[]
  professionals Professional[]  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model City {
  id String @id @default(cuid())
  name String
  provinceId String
  province Province @relation(fields: [provinceId], references: [id])
  users User[]
  professionals Professional[]  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([name, provinceId])
}